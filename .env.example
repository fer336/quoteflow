# ==============================================================================
# QuoteFlow - Variables de Entorno
# ==============================================================================
# Este archivo sirve como DOCUMENTACIÓN de todas las variables.
# Los valores reales se cargan desde el SECRETO budgetpro_backend_env_v2
# (configurado en Docker Swarm / Portainer).
#
# NUNCA commitear el .env real con secretos al repo.

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# postgresql://user:password@host:5432/budgetpro_db
DATABASE_URL=

# ------------------------------------------------------------------------------
# AUTH - JWT
# ------------------------------------------------------------------------------
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
SECRET_KEY=

# Tiempo de expiración de tokens en minutos (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# GOOGLE AUTH
# ------------------------------------------------------------------------------
# Client ID de Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------------------
# MINIO (Object Storage)
# ------------------------------------------------------------------------------
# Endpoint del servicio MinIO
MINIO_ENDPOINT=minio.qeva.xyz

# Credenciales de acceso MinIO
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Bucket para logos de empresas
MINIO_BUCKET=budgetpro-logos

# Usar SSL para conexiones (true/false)
MINIO_USE_SSL=true