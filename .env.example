# ==============================================================================
# QuoteFlow - Variables de Entorno
# ==============================================================================
# Copiar este archivo como .env en producción y completar con los valores reales.
# NUNCA commitear el .env real con secretos al repo.

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# URL de conexión a PostgreSQL (producción)
DATABASE_URL=postgresql://user:password@localhost:5432/budgetpro_db

# ------------------------------------------------------------------------------
# AUTH - JWT
# ------------------------------------------------------------------------------
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
SECRET_KEY=

# Tiempo de expiración de tokens en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# GOOGLE AUTH
# ------------------------------------------------------------------------------
# Client ID de Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
# Orígenes permitidos separados por coma
CORS_ORIGINS=https://presupuestos.octopustrack.shop,http://presupuestos.octopustrack.shop

# ------------------------------------------------------------------------------
# MINIO (Object Storage)
# ------------------------------------------------------------------------------
# Endpoint del servicio MinIO
MINIO_ENDPOINT=minio.qeva.xyz

# Credenciales de acceso
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Bucket para logos de empresas
MINIO_BUCKET=budgetpro-logos

# Usar SSL para conexiones
MINIO_USE_SSL=true

# ------------------------------------------------------------------------------
# FRONTEND (para build)
# ------------------------------------------------------------------------------
# URL del API en producción
VITE_API_URL=https://presupuestos.octopustrack.shop/api

# Client ID de Google para OAuth (debe coincidir con GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=